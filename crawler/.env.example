# ============================================
# Database Configuration
# ============================================
# IMPORTANT: This must match the same DATABASE_URL in api/.env
# Both API and Crawler share the same database

# SQLite (Default - shared database, no server required)
# Uses project root's data/trader.db - automatically shared between API and Crawler
DATABASE_URL=sqlite:///data/trader.db

# MySQL (For production with higher concurrency)
# DATABASE_URL=mysql+pymysql://trader_user:trader_password@localhost:3306/trader

# PostgreSQL (Alternative option)
# DATABASE_URL=postgresql://trader_user:trader_password@localhost:5432/trader

# ============================================
# Crawler Configuration
# ============================================
CRAWLER_DELAY_SECONDS=1
CRAWLER_MAX_RETRIES=3

# ============================================
# Riot API Configuration (if needed)
# ============================================
# RIOT_API_KEY=your-riot-api-key-here

# ============================================
# Other Configuration
# ============================================
DEBUG=true
