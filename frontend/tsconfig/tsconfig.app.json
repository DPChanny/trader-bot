{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2024", "DOM", "DOM.Iterable"],

    "paths": {
      "@pages/*": ["../src/pages/*"],
      "@components/*": ["../src/components/*"],
      "@styles/*": ["../src/styles/*"],
      "@apis/*": ["../src/apis/*"],
      "@hooks/*": ["../src/hooks/*"],
      "@dtos/*": ["../src/dtos/*"],
      "@utils/*": ["../src/utils/*"]
    },
    "types": ["vite/client"],

    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "include": ["../src"]
}