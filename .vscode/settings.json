{
  "python-envs.defaultEnvManager": "ms-python.python:venv",
  "python-envs.defaultPackageManager": "ms-python.python:pip",
  "python.defaultInterpreterPath": "${workspaceFolder}/python/.venv/Scripts/python.exe",
  "python.analysis.extraPaths": ["${workspaceFolder}/python"],
  "python.autoComplete.extraPaths": ["${workspaceFolder}/python"],

  "files.exclude": {
    "**/*.css.d.ts": true,
    "**/__pycache__": true,
    "python/**/logs": true,
    "python/.venv": true,
    "python/.ruff_cache": true,
    "frontend/.tanstack": true,
    "frontend/node_modules": true
  },

  "Lua.diagnostics.globals": ["redis", "KEYS", "ARGV", "cjson"]
}
