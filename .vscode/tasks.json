{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/web" },
      "presentation": { "panel": "dedicated" }
    },
    {
      "label": "Run Backend",
      "type": "shell",
      "command": "uv run python -m uvicorn api.main:app --reload --host localhost --port 8000",
      "options": { "cwd": "${workspaceFolder}/python" },
      "presentation": { "panel": "dedicated" }
    },
    {
      "label": "Run Bot",
      "type": "shell",
      "command": "uv run python -m bot.main",
      "options": { "cwd": "${workspaceFolder}/python" },
      "presentation": { "panel": "dedicated" }
    },
    {
      "label": "CSS: Watch",
      "type": "shell",
      "command": "npm run css:dts",
      "options": { "cwd": "${workspaceFolder}/web" },
      "runOptions": { "runOn": "folderOpen" },
      "presentation": { "reveal": "silent", "panel": "shared" }
    },
    {
      "label": "Run All",
      "dependsOn": ["Run Frontend", "Run Backend", "Run Bot"],
      "dependsOrder": "parallel",
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
