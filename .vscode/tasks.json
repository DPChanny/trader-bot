{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Frontend Dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "presentation": { "panel": "dedicated" }
    },
    {
      "label": "Run Backend Dev",
      "type": "shell",
      "command": "uv run python -m uvicorn backend.main:app --reload --host 127.0.0.1 --port 8000",
      "options": { "cwd": "${workspaceFolder}/python" },
      "presentation": { "panel": "dedicated" }
    },
    {
      "label": "Run Bot Dev",
      "type": "shell",
      "command": "uv run python -m bot.main",
      "options": { "cwd": "${workspaceFolder}/python" },
      "presentation": { "panel": "dedicated" }
    },
    {
      "label": "Run Auction Dev",
      "type": "shell",
      "command": "uv run python -m auction.main",
      "options": { "cwd": "${workspaceFolder}/python" },
      "presentation": { "panel": "dedicated" }
    },
    {
      "label": "Run Database Dev",
      "type": "shell",
      "command": "docker compose -f infra/postgres/docker/docker-compose.yml up -d postgres",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "panel": "dedicated" }
    },
    {
      "label": "Run Redis Dev",
      "type": "shell",
      "command": "docker compose -f infra/redis/docker-compose.yml up -d redis",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "panel": "dedicated" }
    },
    {
      "label": "Run DTS Watch",
      "type": "shell",
      "command": "npm run generate:dts:watch",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "runOptions": { "runOn": "folderOpen" },
      "presentation": { "reveal": "silent", "panel": "shared" },
      "isBackground": true
    },
    {
      "label": "Run Manifest Watch",
      "type": "shell",
      "command": "npm run generate:manifest:watch",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "runOptions": { "runOn": "folderOpen" },
      "presentation": { "reveal": "silent", "panel": "shared" },
      "isBackground": true
    },
    {
      "label": "Run All Dev",
      "dependsOn": [
        "Run Database Dev",
        "Run Redis Dev",
        "Run Frontend Dev",
        "Run Backend Dev",
        "Run Bot Dev",
        "Run Auction Dev"
      ],
      "dependsOrder": "parallel",
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
